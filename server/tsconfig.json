
{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "strict": false,
        "esModuleInterop": true,
        "skipDefaultLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist"
    },
    "include": ["src"],
    "exclude": ["node_modules"]
